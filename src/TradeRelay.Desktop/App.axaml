<Application
    x:Class="TradeRelay.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Name="TradeRelay"
    RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button">
      <Setter Property="Padding" Value="16,9" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#24313F" />
      <Setter Property="Foreground" Value="#E7EDF3" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#314152" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#2C8065" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#359777" />
    </Style>
    <Style Selector="Button.quiet">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#415163" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#F3F6F8" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#A9B7C5" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="#E7EDF3" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Application.Styles>
</Application>
