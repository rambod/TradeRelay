<Application
    x:Class="TradeRelay.Desktop.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Name="TradeRelay"
    RequestedThemeVariant="Dark">
  <Application.Resources>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1118" />
    <SolidColorBrush x:Key="ShellBrush" Color="#101923" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#16212C" />
    <SolidColorBrush x:Key="SecondarySurfaceBrush" Color="#1B2835" />
    <SolidColorBrush x:Key="BorderBrush" Color="#334454" />
    <SolidColorBrush x:Key="InkBrush" Color="#F2F6F8" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="#B8C6D2" />
    <SolidColorBrush x:Key="AccentBrush" Color="#35C9E8" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#57D6A5" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F0CA67" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F08A93" />
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="{DynamicResource SecondarySurfaceBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#314152" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Foreground" Value="#07151B" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#63D8EE" />
    </Style>
    <Style Selector="Button.quiet">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource MutedInkBrush}" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#46242B" />
      <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
      <Setter Property="BorderBrush" Value="#7D3E49" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button:focus /template/ ContentPresenter">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="44" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="MinHeight" Value="44" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="Border.warningPanel">
      <Setter Property="Background" Value="#2B2618" />
      <Setter Property="BorderBrush" Value="#675B2C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Border.infoBadge">
      <Setter Property="Background" Value="#12313C" />
      <Setter Property="BorderBrush" Value="#28758A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style Selector="TextBlock.fieldLabel">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource InkBrush}" />
    </Style>
    <Style Selector="TextBlock.statusText">
      <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style Selector="TextBlock.warningText">
      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="TextBlock.warningTitle">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="Menlo,Consolas,monospace" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource MutedInkBrush}" />
    </Style>
  </Application.Styles>
</Application>
