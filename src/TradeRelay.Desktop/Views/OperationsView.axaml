<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:viewModels="using:TradeRelay.Desktop.ViewModels" xmlns:core="using:TradeRelay.Core.Models" x:Class="TradeRelay.Desktop.Views.OperationsView" x:DataType="viewModels:OperationsViewModel">
  <Grid Margin="26" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="14">
    <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="4"><TextBlock Classes="sectionTitle" Text="Operations"/><TextBlock Classes="muted" Text="Current exchange state and clearly sourced lifecycle history. No desktop order placement."/></StackPanel><Button Grid.Column="1" Classes="quiet" Command="{Binding RefreshCommand}" Content="Refresh"/></Grid>
    <Grid Grid.Row="1" ColumnDefinitions="150,*,*,*,Auto" ColumnSpacing="18"><StackPanel><TextBlock Classes="muted" Text="EXCHANGE FILTER"/><ComboBox AutomationProperties.Name="Operations exchange filter" ItemsSource="{Binding Exchanges}" SelectedItem="{Binding SelectedExchange}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Classes="muted" Text="PROVIDER"/><TextBlock Classes="value" Text="{Binding ProviderLabel}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Classes="muted" Text="GROSS EXPOSURE"/><TextBlock Classes="value" Text="{Binding GrossExposure, StringFormat='USDT {0}'}"/></StackPanel><StackPanel Grid.Column="3"><TextBlock Classes="muted" Text="NET EXPOSURE"/><TextBlock Classes="value" Text="{Binding NetExposure, StringFormat='USDT {0}'}"/></StackPanel><TextBlock Grid.Column="4" Classes="muted" Text="{Binding LastRefresh}" VerticalAlignment="Bottom"/></Grid>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6"><Button Classes="quiet" Command="{Binding ShowPositionsCommand}" Content="Positions"/><Button Classes="quiet" Command="{Binding ShowOrdersCommand}" Content="Orders"/><Button Classes="quiet" Command="{Binding ShowFillsCommand}" Content="Fills"/><Button Classes="quiet" Command="{Binding ShowProtectionCommand}" Content="Protection"/></StackPanel>
    <Border Grid.Row="3" Classes="panel" Padding="12">
      <Grid>
        <Grid IsVisible="{Binding IsPositionsSelected}" RowDefinitions="Auto,*" RowSpacing="6"><Grid ColumnDefinitions="100,80,80,90,90,100,90,80,100,*" ColumnSpacing="8"><TextBlock Classes="muted" Text="SYMBOL"/><TextBlock Grid.Column="1" Classes="muted" Text="SIDE"/><TextBlock Grid.Column="2" Classes="muted" Text="QTY"/><TextBlock Grid.Column="3" Classes="muted" Text="ENTRY"/><TextBlock Grid.Column="4" Classes="muted" Text="MARK"/><TextBlock Grid.Column="5" Classes="muted" Text="EXPOSURE"/><TextBlock Grid.Column="6" Classes="muted" Text="PNL"/><TextBlock Grid.Column="7" Classes="muted" Text="LEV."/><TextBlock Grid.Column="8" Classes="muted" Text="LIQ. DIST."/><TextBlock Grid.Column="9" Classes="muted" Text="STATE"/></Grid><ListBox Grid.Row="1" ItemsSource="{Binding Positions}"><ListBox.ItemTemplate><DataTemplate x:DataType="viewModels:PositionOperationRow"><Grid Margin="4,6" ColumnDefinitions="100,80,80,90,90,100,90,80,100,*" ColumnSpacing="8"><TextBlock Text="{Binding Symbol}"/><TextBlock Grid.Column="1" FontWeight="SemiBold" Text="{Binding Direction}"/><TextBlock Grid.Column="2" Text="{Binding Quantity}"/><TextBlock Grid.Column="3" Text="{Binding EntryPrice}"/><TextBlock Grid.Column="4" Text="{Binding MarkPrice}"/><TextBlock Grid.Column="5" Text="{Binding Exposure}"/><TextBlock Grid.Column="6" Text="{Binding UnrealizedPnl}"/><TextBlock Grid.Column="7" Text="{Binding Leverage}"/><TextBlock Grid.Column="8" Text="{Binding LiquidationDistance}"/><TextBlock Grid.Column="9" Classes="muted" Text="{Binding Reconciliation}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
        <Grid IsVisible="{Binding IsOrdersSelected}" RowDefinitions="Auto,*" RowSpacing="8"><TextBlock Classes="muted" Text="Exchange-returned recent history; open orders are reconciled separately."/><ListBox Grid.Row="1" ItemsSource="{Binding OrderHistory}"><ListBox.ItemTemplate><DataTemplate x:DataType="core:HistoricalOrder"><Grid Margin="6" ColumnDefinitions="110,90,80,*,110,110" ColumnSpacing="8"><TextBlock Text="{Binding Symbol}"/><TextBlock Grid.Column="1" Text="{Binding Side}"/><TextBlock Grid.Column="2" Text="{Binding Type}"/><TextBlock Grid.Column="3" Text="{Binding ExchangeOrderId}"/><TextBlock Grid.Column="4" Text="{Binding Status}"/><TextBlock Grid.Column="5" Classes="muted" Text="{Binding UpdatedTimeUtc, StringFormat='{}{0:MM-dd HH:mm}'}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
        <Grid IsVisible="{Binding IsFillsSelected}" RowDefinitions="Auto,*" RowSpacing="8"><TextBlock Classes="muted" Text="Exchange-returned executions. TradeRelay does not fabricate fills from audit events."/><ListBox Grid.Row="1" ItemsSource="{Binding Fills}"><ListBox.ItemTemplate><DataTemplate x:DataType="core:HistoricalExecution"><Grid Margin="6" ColumnDefinitions="110,80,100,100,*,110" ColumnSpacing="8"><TextBlock Text="{Binding Symbol}"/><TextBlock Grid.Column="1" Text="{Binding Side}"/><TextBlock Grid.Column="2" Text="{Binding Quantity}"/><TextBlock Grid.Column="3" Text="{Binding Price}"/><TextBlock Grid.Column="4" Text="{Binding ExecutionId}"/><TextBlock Grid.Column="5" Classes="muted" Text="{Binding TimestampUtc, StringFormat='{}{0:MM-dd HH:mm}'}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
        <Grid IsVisible="{Binding IsProtectionSelected}" RowDefinitions="Auto,*" RowSpacing="8"><TextBlock Classes="muted" Text="Current stop-loss and take-profit coverage from the exchange position snapshot."/><ListBox Grid.Row="1" ItemsSource="{Binding Positions}"><ListBox.ItemTemplate><DataTemplate x:DataType="viewModels:PositionOperationRow"><Grid Margin="6" ColumnDefinitions="120,90,*,140" ColumnSpacing="8"><TextBlock Text="{Binding Symbol}"/><TextBlock Grid.Column="1" Text="{Binding Direction}"/><TextBlock Grid.Column="2" Text="{Binding Protection}"/><TextBlock Grid.Column="3" Classes="muted" Text="{Binding Reconciliation}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
        <StackPanel IsVisible="{Binding IsLoading}" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"><ProgressBar IsIndeterminate="True" Width="220"/><TextBlock Classes="muted" Text="Reconciling exchange state…"/></StackPanel>
        <StackPanel IsVisible="{Binding IsEmpty}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="430" Spacing="8"><TextBlock FontSize="18" FontWeight="SemiBold" Text="No active operations loaded" HorizontalAlignment="Center"/><TextBlock Classes="muted" Text="Connect an account or refresh. Historical exchange records remain explicitly labeled and TradeRelay never invents activity from before it observed the account." TextAlignment="Center" TextWrapping="Wrap"/><TextBlock Classes="warningText" Text="{Binding Error}" TextWrapping="Wrap"/></StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
