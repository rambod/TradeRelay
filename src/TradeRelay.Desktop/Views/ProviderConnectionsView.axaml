<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:viewModels="using:TradeRelay.Desktop.ViewModels" x:Class="TradeRelay.Desktop.Views.ProviderConnectionsView" x:DataType="viewModels:ProviderConnectionsViewModel">
  <Border Classes="panel" Padding="20"><Grid ColumnDefinitions="2*,3*" ColumnSpacing="20">
    <StackPanel Spacing="10"><TextBlock FontWeight="SemiBold" Text="Additional exchanges"/><TextBlock Classes="muted" Text="Connect Binance and KuCoin concurrently for Live account inspection. These adapters expose no write capability." TextWrapping="Wrap"/><TextBlock Classes="fieldLabel" Text="Exchange"/><ComboBox AutomationProperties.Name="Read-only exchange provider" ItemsSource="{Binding Exchanges}" SelectedItem="{Binding SelectedExchange}"/><TextBlock Classes="muted" Text="{Binding Capabilities}" TextWrapping="Wrap"/>
      <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="REST health"/><TextBlock Grid.Column="1" Text="{Binding RestHealth}"/></Grid><Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Private stream"/><TextBlock Grid.Column="1" Text="{Binding StreamHealth}"/></Grid><Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Saved key"/><TextBlock Grid.Column="1" Text="{Binding SavedKeyPreview}"/></Grid>
    </StackPanel>
    <StackPanel Grid.Column="1" Spacing="8"><ItemsControl ItemsSource="{Binding CredentialFields}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="viewModels:ProviderCredentialFieldViewModel"><StackPanel Spacing="5" Margin="0,0,0,8"><TextBlock Classes="fieldLabel" Text="{Binding Label}"/><TextBox AutomationProperties.Name="{Binding Label}" PasswordChar="{Binding PasswordChar}" Text="{Binding Value}"/></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><CheckBox IsChecked="{Binding Remember}" Content="Remember using protected device storage"/><TextBlock Classes="warningText" Text="Read-only adapter: TradeRelay cannot place, cancel, close, or modify protection on this exchange." TextWrapping="Wrap"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Command="{Binding TestCommand}" Content="Test"/><Button Classes="primary" Command="{Binding SaveCommand}" Content="Save &amp; connect"/><Button Classes="danger" Command="{Binding DeleteCommand}" Content="Delete"/></StackPanel><TextBlock Classes="statusText" Text="{Binding Status}" TextWrapping="Wrap"/></StackPanel>
  </Grid></Border>
</UserControl>
