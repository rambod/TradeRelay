<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:viewModels="using:TradeRelay.Desktop.ViewModels" xmlns:core="using:TradeRelay.Core.Models" xmlns:services="using:TradeRelay.Desktop.Services" x:Class="TradeRelay.Desktop.Views.AgentClientsView" x:DataType="viewModels:AgentClientsViewModel">
  <Border Classes="panel" Padding="20"><StackPanel Spacing="14">
    <StackPanel Spacing="4"><TextBlock FontWeight="SemiBold" Text="Agent Clients"/><TextBlock Classes="muted" Text="Detect, install, pair, repair, revoke, or uninstall Codex, Claude Code, and Gemini CLI integrations. Every command and target is previewed first." TextWrapping="Wrap"/></StackPanel>
    <Grid ColumnDefinitions="2*,3*" ColumnSpacing="16">
      <StackPanel Spacing="8"><ListBox ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}"><ListBox.ItemTemplate><DataTemplate x:DataType="services:AgentClientStatus"><Grid Margin="5" ColumnDefinitions="*,Auto"><StackPanel><TextBlock Classes="value" Text="{Binding DisplayName}"/><TextBlock Classes="muted" Text="{Binding Version}"/></StackPanel><StackPanel Grid.Column="1" HorizontalAlignment="Right"><TextBlock Text="{Binding State}"/><TextBlock Classes="warningText" Text="{Binding SafeError}" MaxWidth="220" TextWrapping="Wrap"/></StackPanel></Grid></DataTemplate></ListBox.ItemTemplate></ListBox><StackPanel Orientation="Horizontal" Spacing="8"><Button Classes="quiet" Command="{Binding DetectCommand}" Content="Detect"/><Button Classes="quiet" Command="{Binding PreviewInstallCommand}" Content="Preview"/><Button Classes="quiet" Command="{Binding UninstallCommand}" Content="Uninstall"/></StackPanel></StackPanel>
      <StackPanel Grid.Column="1" Spacing="8"><TextBlock Classes="fieldLabel" Text="Installation preview"/><TextBox MinHeight="130" IsReadOnly="True" AcceptsReturn="True" Text="{Binding Preview}" FontFamily="Menlo,Consolas,monospace" TextWrapping="Wrap"/><CheckBox IsChecked="{Binding InstallationAcknowledged}" Content="I reviewed these exact commands and targets."/><Button Classes="primary" HorizontalAlignment="Left" Command="{Binding InstallCommand}" Content="Install / Repair"/></StackPanel>
    </Grid>
    <Separator/>
    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
      <StackPanel Spacing="8"><TextBlock Classes="fieldLabel" Text="Pending OAuth pairing"/><ListBox MinHeight="72" ItemsSource="{Binding PendingPairings}" SelectedItem="{Binding SelectedPairing}"><ListBox.ItemTemplate><DataTemplate x:DataType="core:OAuthPairingSnapshot"><StackPanel Margin="5"><TextBlock Classes="value" Text="{Binding ClientName}"/><TextBlock Classes="muted" Text="{Binding RequestedScopes}"/><TextBlock Classes="mono" Text="{Binding PairingId}"/></StackPanel></DataTemplate></ListBox.ItemTemplate></ListBox><CheckBox IsChecked="{Binding GrantTradeScope}" Content="Also grant Trade scope (desktop gates still apply)"/><StackPanel Orientation="Horizontal" Spacing="8"><Button Classes="primary" Command="{Binding ApprovePairingCommand}" Content="Approve pairing"/><Button Classes="danger" Command="{Binding RejectPairingCommand}" Content="Reject"/></StackPanel></StackPanel>
      <StackPanel Grid.Column="1" Spacing="8"><TextBlock Classes="fieldLabel" Text="Paired clients"/><ListBox MinHeight="72" ItemsSource="{Binding PairedClients}" SelectedItem="{Binding SelectedOAuthClient}"><ListBox.ItemTemplate><DataTemplate x:DataType="core:OAuthClientSnapshot"><Grid Margin="5" ColumnDefinitions="*,Auto"><StackPanel><TextBlock Classes="value" Text="{Binding ClientName}"/><TextBlock Classes="muted" Text="{Binding GrantedScopes}"/></StackPanel><TextBlock Grid.Column="1" Text="{Binding LastSeenUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/></Grid></DataTemplate></ListBox.ItemTemplate></ListBox><Button Classes="danger" HorizontalAlignment="Left" Command="{Binding RevokeClientCommand}" Content="Revoke / Re-pair"/></StackPanel>
    </Grid>
    <TextBlock Classes="statusText" Text="{Binding Status}" TextWrapping="Wrap"/>
  </StackPanel></Border>
</UserControl>
