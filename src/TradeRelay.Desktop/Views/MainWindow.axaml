<Window
    x:Class="TradeRelay.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TradeRelay.Desktop.ViewModels"
    xmlns:localViews="using:TradeRelay.Desktop.Views"
    x:DataType="viewModels:MainWindowViewModel"
    Title="{Binding ApplicationName}"
    Width="1080" Height="720" MinWidth="900" MinHeight="640"
    Icon="avares://TradeRelay/Assets/TradeRelay.png"
    Background="{DynamicResource AppBackgroundBrush}">
  <Grid RowDefinitions="64,*">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="{Binding NavigationRailWidth}" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Border Grid.RowSpan="2" Background="{DynamicResource ShellBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="64,*,Auto">
        <Grid Margin="18,0" ColumnDefinitions="Auto,*" ColumnSpacing="10">
          <Border Width="30" Height="30" CornerRadius="7" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center">
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="#07151B" Text="TR" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center" IsVisible="{Binding !IsCompactNavigation}">
            <TextBlock FontWeight="SemiBold" Text="TradeRelay" />
            <TextBlock Classes="muted" FontSize="11" Text="{Binding VersionLabel}" />
          </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Margin="10,18" Spacing="4">
          <TextBlock Margin="10,0,0,6" Classes="muted" FontSize="11" Text="WORKSPACES" IsVisible="{Binding !IsCompactNavigation}" />
          <Button Classes="rail" Command="{Binding ShowOverviewCommand}" Content="{Binding OverviewNavLabel}" AutomationProperties.Name="Overview" />
          <Button Classes="rail" Command="{Binding ShowOperationsCommand}" Content="{Binding OperationsNavLabel}" AutomationProperties.Name="Operations" />
          <Button Classes="rail" Command="{Binding ShowApprovalsCommand}" Content="{Binding ApprovalsNavLabel}" AutomationProperties.Name="Approvals" />
          <Button Classes="rail" Command="{Binding ShowActivityCommand}" Content="{Binding ActivityNavLabel}" AutomationProperties.Name="Activity" />
          <Separator Margin="8,12" Background="{DynamicResource BorderBrush}" />
          <TextBlock Margin="10,0,0,6" Classes="muted" FontSize="11" Text="CONTROL" IsVisible="{Binding !IsCompactNavigation}" />
          <Button Classes="rail" Command="{Binding ShowConnectionsCommand}" Content="{Binding ConnectionsNavLabel}" AutomationProperties.Name="Connections" />
          <Button Classes="rail" Command="{Binding ShowRiskCommand}" Content="{Binding RiskNavLabel}" AutomationProperties.Name="Risk" />
          <Button Classes="rail" Command="{Binding ShowSettingsCommand}" Content="{Binding SettingsNavLabel}" AutomationProperties.Name="Settings" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="18,14" Spacing="4" IsVisible="{Binding !IsCompactNavigation}">
          <TextBlock Classes="muted" FontSize="11" Text="WRITES RESET ON LAUNCH" />
          <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding TradingState}" TextWrapping="Wrap" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Column="1" Padding="20,0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto" ColumnSpacing="18">
        <StackPanel VerticalAlignment="Center" Spacing="2">
          <TextBlock Classes="muted" FontSize="11" Text="EXCHANGE" />
          <TextBlock Classes="value" Text="{Binding SelectedProviderName}" />
        </StackPanel>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
          <TextBlock Classes="muted" FontSize="11" Text="ENVIRONMENT" />
          <TextBlock Classes="value" Text="{Binding EnvironmentStatus}" />
        </StackPanel>
        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
          <TextBlock Classes="muted" FontSize="11" Text="REST · STREAM · AUDIT" />
          <TextBlock Classes="value" Text="{Binding HealthSummary}" />
        </StackPanel>
        <Border Grid.Column="4" Classes="infoBadge" IsVisible="{Binding IsHeaderDemo}" Padding="12,7" VerticalAlignment="Center">
          <TextBlock FontWeight="SemiBold" Text="{Binding HeaderSafetyState}" />
        </Border>
        <Border Grid.Column="4" Classes="liveBadge" IsVisible="{Binding IsHeaderLive}" Padding="12,7" VerticalAlignment="Center">
          <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="{Binding HeaderSafetyState}" />
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Grid.Column="1">
      <ScrollViewer IsVisible="{Binding IsDashboardSelected}">
        <StackPanel Margin="26" Spacing="20">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Spacing="4"><TextBlock Classes="sectionTitle" Text="Overview"/><TextBlock Classes="muted" Text="Live-grade operating posture. Exchange writes remain explicitly session-enabled."/></StackPanel>
            <Button Grid.Column="1" Classes="danger" IsVisible="{Binding IsTradingEnabled}" Command="{Binding DisableTradingCommand}" Content="Disable New Trading Actions" />
          </Grid>
          <Grid ColumnDefinitions="2*,3*" ColumnSpacing="18">
            <StackPanel Spacing="16">
              <Border Classes="panel" Padding="18"><StackPanel Spacing="12">
                <TextBlock FontWeight="SemiBold" Text="Safety posture"/>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Trading access"/><TextBlock Grid.Column="1" Classes="value" Text="{Binding AccessStatus}"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Open positions"/><TextBlock Grid.Column="1" Classes="value" Text="{Binding OpenPositionCount}"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Open orders"/><TextBlock Grid.Column="1" Classes="value" Text="{Binding OpenOrderCount}"/></Grid>
                <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Pending approvals"/><TextBlock Grid.Column="1" Classes="value" Text="{Binding PendingApprovalCount}"/></Grid>
                <Separator Background="{DynamicResource BorderBrush}"/>
                <TextBlock Classes="muted" Text="{Binding TradingDetail}" TextWrapping="Wrap"/>
                <CheckBox IsVisible="{Binding IsDemoEnvironment}" IsChecked="{Binding TradingAcknowledged}" Content="I understand this writes to Bybit Demo."/>
                <Button Classes="primary" IsVisible="{Binding ShowDemoEnable}" Command="{Binding EnableDemoTradingCommand}" Content="Enable Demo trading"/>
                <Button Classes="danger" IsVisible="{Binding ShowLiveEnable}" Command="{Binding OpenLiveEnableDialogCommand}" Content="Review and enable Live"/>
              </StackPanel></Border>
              <Border Classes="warningPanel" Padding="16"><TextBlock Classes="warningText" Text="Disabling or stopping TradeRelay blocks new writes only. It never cancels orders, closes positions, or removes protection." TextWrapping="Wrap"/></Border>
            </StackPanel>
            <Border Grid.Column="1" Classes="panel" Padding="20"><StackPanel Spacing="14">
              <Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock FontWeight="SemiBold" Text="Local MCP server"/><TextBlock Classes="muted" Text="Loopback-only Streamable HTTP"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><Button Classes="primary" Command="{Binding StartServerCommand}" Content="Start MCP"/><Button Command="{Binding StopServerCommand}" Content="Stop"/></StackPanel></Grid>
              <Separator Background="{DynamicResource BorderBrush}"/>
              <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <TextBlock Classes="muted" Text="State"/><TextBlock Grid.Column="1" Classes="value" Text="{Binding ServerState}"/>
                <TextBlock Grid.Row="1" Classes="muted" Text="Endpoint"/><TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Text="{Binding Endpoint}" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="2" Classes="muted" Text="Authentication"/><TextBlock Grid.Row="2" Grid.Column="1" Classes="value" Text="{Binding AuthenticationStatus}"/>
                <TextBlock Grid.Row="3" Classes="muted" Text="Last error"/><TextBlock Grid.Row="3" Grid.Column="1" Classes="value" Text="{Binding LastError}" TextWrapping="Wrap"/>
              </Grid>
              <TextBlock Classes="statusText" Text="{Binding ActionMessage}" TextWrapping="Wrap"/>
            </StackPanel></Border>
          </Grid>
        </StackPanel>
      </ScrollViewer>

      <Grid IsVisible="{Binding IsOperationsSelected}"><localViews:OperationsView DataContext="{Binding Operations}"/></Grid>

      <ScrollViewer IsVisible="{Binding IsCredentialsSelected}">
        <StackPanel Margin="26" Spacing="20">
          <StackPanel Spacing="4"><TextBlock Classes="sectionTitle" Text="Connections"/><TextBlock Classes="muted" Text="Exchange credentials and local agent connectivity in one controlled workspace."/></StackPanel>
          <Grid ColumnDefinitions="3*,2*" ColumnSpacing="18">
            <Border Classes="panel" Padding="20"><StackPanel Spacing="12">
              <TextBlock FontWeight="SemiBold" Text="Bybit account"/><ComboBox ItemsSource="{Binding Environments}" SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}"/>
              <TextBox Text="{Binding ApiKey, Mode=TwoWay}" PasswordChar="●" PlaceholderText="API key"/>
              <TextBox Text="{Binding ApiSecret, Mode=TwoWay}" PasswordChar="●" PlaceholderText="API secret"/>
              <CheckBox Content="Remember this environment in protected storage" IsChecked="{Binding RememberCredentials, Mode=TwoWay}"/>
              <StackPanel Orientation="Horizontal" Spacing="8"><Button Command="{Binding TestConnectionCommand}" Content="Test"/><Button Classes="primary" Command="{Binding SaveCredentialsCommand}" Content="Save"/><Button Command="{Binding DeleteCredentialsCommand}" Content="Delete"/></StackPanel>
              <TextBlock Classes="statusText" Text="{Binding CredentialActionStatus}" TextWrapping="Wrap"/>
              <Separator Background="{DynamicResource BorderBrush}"/>
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Saved key"/><TextBlock Grid.Column="1" Text="{Binding SavedKeyPreview}"/></Grid>
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Storage"/><TextBlock Grid.Column="1" Text="{Binding CredentialStorageStatus}"/></Grid>
              <TextBlock Classes="muted" Text="{Binding PermissionSummary}" TextWrapping="Wrap"/><TextBlock Classes="warningText" Text="{Binding CredentialWarnings}" TextWrapping="Wrap"/>
            </StackPanel></Border>
            <Border Grid.Column="1" Classes="panel" Padding="20"><StackPanel Spacing="12">
              <TextBlock FontWeight="SemiBold" Text="Advanced compatibility"/><TextBlock Classes="muted" Text="OAuth pairing is preferred. Use this legacy bearer token only for clients that cannot pair directly." TextWrapping="Wrap"/>
              <TextBox IsReadOnly="True" FontFamily="Menlo,Consolas,monospace" Text="{Binding DisplayedToken}"/>
              <WrapPanel><Button Classes="quiet" Command="{Binding ToggleTokenVisibilityCommand}" Content="{Binding TokenVisibilityAction}"/><Button Classes="quiet" Command="{Binding CopyTokenCommand}" Content="Copy token"/><Button Classes="quiet" Command="{Binding RotateTokenCommand}" Content="Rotate"/></WrapPanel>
              <Button Command="{Binding CopyCodexConfigCommand}" Content="Copy Codex config"/><Button Command="{Binding CopyClaudeCodeCommand}" Content="Copy Claude Code command"/>
            </StackPanel></Border>
          </Grid>
          <localViews:ProviderConnectionsView DataContext="{Binding ProviderConnections}"/>
          <localViews:AgentClientsView DataContext="{Binding AgentClients}"/>
        </StackPanel>
      </ScrollViewer>

      <Grid IsVisible="{Binding IsRiskSelected}"><localViews:RiskView DataContext="{Binding Risk}"/></Grid>
      <Grid IsVisible="{Binding IsApprovalsSelected}"><localViews:ApprovalsView DataContext="{Binding Approvals}"/></Grid>
      <Grid IsVisible="{Binding IsActivitySelected}"><localViews:ActivityView DataContext="{Binding Activity}"/></Grid>
      <Grid IsVisible="{Binding IsSettingsSelected}"><localViews:SettingsView DataContext="{Binding Settings}"/></Grid>
    </Grid>

    <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Background="#E60B1118" IsVisible="{Binding IsLiveEnableDialogOpen}">
      <Border Classes="panel" Width="620" MaxHeight="580" Padding="26" HorizontalAlignment="Center" VerticalAlignment="Center">
        <ScrollViewer><StackPanel Spacing="16">
          <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="Enable Live trading"/>
          <TextBlock Classes="muted" Text="This enables real Bybit mainnet writes for this application session only." TextWrapping="Wrap"/>
          <Border Classes="liveBadge" Padding="16"><StackPanel Spacing="8"><TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="LIVE · REAL FUNDS AND POSITIONS"/><TextBlock Text="{Binding LiveRiskSummary}" TextWrapping="Wrap"/></StackPanel></Border>
          <TextBlock Classes="warningText" Text="{Binding LiveEnableWarnings}" TextWrapping="Wrap"/>
          <TextBlock Classes="fieldLabel" Text="Type ENABLE LIVE TRADING exactly"/><TextBox Text="{Binding LiveConfirmationText, Mode=TwoWay}"/>
          <TextBlock Classes="muted" Text="Disabling later blocks only new writes; it does not alter existing exchange state." TextWrapping="Wrap"/>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"><Button Classes="quiet" Command="{Binding CancelLiveEnableCommand}" Content="Cancel"/><Button Classes="danger" Command="{Binding ConfirmLiveEnableCommand}" Content="Enable Live trading"/></StackPanel>
        </StackPanel></ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
