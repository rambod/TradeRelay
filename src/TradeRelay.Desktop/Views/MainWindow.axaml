<Window
    x:Class="TradeRelay.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:TradeRelay.Desktop.ViewModels"
    xmlns:localViews="using:TradeRelay.Desktop.Views"
    x:DataType="viewModels:MainWindowViewModel"
    Title="{Binding ApplicationName}"
    Width="1080"
    Height="720"
    MinWidth="900"
    MinHeight="640"
    Background="{DynamicResource AppBackgroundBrush}">
  <Grid RowDefinitions="Auto,Auto,*">
    <Border
        Padding="32,20"
        Background="#151E28"
        BorderBrush="#2A3644"
        BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="3">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock
                FontSize="23"
                FontWeight="SemiBold"
                Foreground="#F3F6F8"
                Text="{Binding ApplicationName}" />
            <Border
                Padding="8,3"
                VerticalAlignment="Center"
                Background="#203649"
                CornerRadius="6">
              <TextBlock
                  FontSize="12"
                  Foreground="#B9D8EF"
                  Text="{Binding VersionLabel}" />
            </Border>
          </StackPanel>
          <TextBlock
              Classes="muted"
              Text="{Binding DevelopmentStatus}" />
        </StackPanel>
        <Border
            Grid.Column="1"
            IsVisible="{Binding IsDemoEnvironment}"
            Padding="12,7"
            VerticalAlignment="Center"
            Background="#203649"
            BorderBrush="#35607B"
            BorderThickness="1"
            CornerRadius="8">
          <TextBlock
              FontWeight="SemiBold"
              Foreground="#B9D8EF"
              Text="{Binding HeaderSafetyState}" />
        </Border>
        <Border
            Grid.Column="1"
            Classes="liveBadge"
            IsVisible="{Binding IsLiveEnvironment}"
            Padding="12,7"
            VerticalAlignment="Center">
          <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="{Binding HeaderSafetyState}" />
        </Border>
      </Grid>
    </Border>

    <Border Grid.Row="1" Padding="32,10" Background="#111923" BorderBrush="#2A3644" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="quiet" Command="{Binding ShowDashboardCommand}" Content="Dashboard" />
        <Button Classes="quiet" Command="{Binding ShowCredentialsCommand}" Content="Credentials" />
        <Button Classes="quiet" Command="{Binding ShowRiskCommand}" Content="Risk" />
        <Button Classes="quiet" Command="{Binding ShowApprovalsCommand}" Content="Approvals" />
        <Button Classes="quiet" Command="{Binding ShowActivityCommand}" Content="Activity" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2" IsVisible="{Binding IsDashboardSelected}">
      <Grid
          Margin="32"
          ColumnDefinitions="2*,3*"
          ColumnSpacing="24">
        <StackPanel Grid.Column="0" Spacing="18">
          <StackPanel Spacing="5">
            <TextBlock Classes="sectionTitle" Text="Safety posture" />
            <TextBlock
                Classes="muted"
                MaxWidth="420"
                Text="Exchange writes require an explicitly enabled desktop session. Live adds mandatory startup confirmation and stricter action approval."
                TextWrapping="Wrap" />
          </StackPanel>

          <Border
              Padding="20"
              Background="#151E28"
              BorderBrush="#2A3644"
              BorderThickness="1"
              CornerRadius="12">
            <StackPanel Spacing="13">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Environment" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding EnvironmentStatus}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Trading access" />
                <TextBlock Grid.Column="1" Classes="value" Foreground="#8BE0BD" Text="{Binding AccessStatus}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Live trading" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding LiveTradingStatus}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Provider" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding ProviderStatus}" />
              </Grid>
              <Separator Background="#2A3644" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Open positions" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding OpenPositionCount}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Open orders" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding OpenOrderCount}" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="muted" Text="Pending approvals" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding PendingApprovalCount}" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="panel" Padding="18">
            <StackPanel Spacing="10">
              <Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock FontWeight="SemiBold" Text="{Binding TradingState}"/><TextBlock Classes="muted" Text="{Binding TradingDetail}" TextWrapping="Wrap"/></StackPanel><Border Grid.Column="1" Classes="infoBadge" IsVisible="{Binding IsDemoEnvironment}" Padding="10,6"><TextBlock Text="DEMO"/></Border><Border Grid.Column="1" Classes="liveBadge" IsVisible="{Binding IsLiveEnvironment}" Padding="10,6"><TextBlock Foreground="{DynamicResource ErrorBrush}" FontWeight="SemiBold" Text="LIVE"/></Border></Grid>
              <CheckBox IsVisible="{Binding IsDemoEnvironment}" IsChecked="{Binding TradingAcknowledged}" Content="I understand this sends write requests to my Bybit Demo account."/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="primary" IsVisible="{Binding ShowDemoEnable}" Command="{Binding EnableDemoTradingCommand}" Content="Enable Demo trading"/>
                <Button Classes="danger" IsVisible="{Binding ShowLiveEnable}" Command="{Binding OpenLiveEnableDialogCommand}" Content="Review and enable Live"/>
                <Button Classes="danger" IsVisible="{Binding IsTradingEnabled}" Command="{Binding DisableTradingCommand}" Content="Disable New Trading Actions"/>
              </StackPanel>
              <TextBlock Classes="muted" Text="Disabling blocks new writes immediately. It never cancels orders, closes positions, or removes protection." TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border
              Padding="18"
              Background="#242218"
              BorderBrush="#635B32"
              BorderThickness="1"
              CornerRadius="10">
            <StackPanel Spacing="6">
              <TextBlock
                  FontWeight="SemiBold"
                  Foreground="#F1DA85"
                  Text="Stopping is connection-only" />
              <TextBlock
                  Foreground="#D5CBA8"
                  Text="Stopping TradeRelay does not cancel exchange orders, close positions, or remove stop-loss and take-profit protection."
                  TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <StackPanel Spacing="5">
            <TextBlock Classes="sectionTitle" Text="Local MCP server" />
            <TextBlock
                Classes="muted"
                Text="Loopback-only Streamable HTTP with bearer authentication."
                TextWrapping="Wrap" />
          </StackPanel>

          <Border
              Padding="22"
              Background="#151E28"
              BorderBrush="#2A3644"
              BorderThickness="1"
              CornerRadius="12">
            <StackPanel Spacing="17">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="3">
                  <TextBlock Classes="muted" Text="Server state" />
                  <TextBlock
                      FontSize="26"
                      FontWeight="SemiBold"
                      Foreground="#F3F6F8"
                      Text="{Binding ServerState}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                  <Button Classes="primary" Command="{Binding StartServerCommand}" Content="Start MCP" />
                  <Button Command="{Binding StopServerCommand}" Content="Stop" />
                </StackPanel>
              </Grid>

              <Separator Background="#2A3644" />

              <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                <TextBlock Classes="muted" Text="Endpoint" />
                <TextBlock Grid.Column="1" Classes="value" Text="{Binding Endpoint}" TextWrapping="Wrap" />
                <TextBlock Grid.Row="1" Classes="muted" Text="Port" />
                <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Text="{Binding Port}" />
                <TextBlock Grid.Row="2" Classes="muted" Text="Authentication" />
                <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" Text="{Binding AuthenticationStatus}" />
                <TextBlock Grid.Row="3" Classes="muted" Text="Sessions" />
                <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" Text="{Binding SessionStatus}" />
                <TextBlock Grid.Row="4" Classes="muted" Text="Last error" />
                <TextBlock Grid.Row="4" Grid.Column="1" Classes="value" Text="{Binding LastError}" TextWrapping="Wrap" />
              </Grid>

              <Separator Background="#2A3644" />

              <StackPanel Spacing="9">
                <TextBlock FontWeight="SemiBold" Foreground="#E7EDF3" Text="Session bearer token" />
                <TextBox
                    Padding="12,10"
                    Background="#0E141B"
                    BorderBrush="#344354"
                    FontFamily="Menlo,Consolas,monospace"
                    IsReadOnly="True"
                    Text="{Binding DisplayedToken}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Classes="quiet" Command="{Binding ToggleTokenVisibilityCommand}" Content="{Binding TokenVisibilityAction}" />
                  <Button Classes="quiet" Command="{Binding CopyTokenCommand}" Content="Copy token" />
                  <Button Classes="quiet" Command="{Binding RotateTokenCommand}" Content="Rotate token" />
                </StackPanel>
              </StackPanel>

              <StackPanel Spacing="9">
                <TextBlock FontWeight="SemiBold" Foreground="#E7EDF3" Text="Client setup" />
                <TextBlock
                    Classes="muted"
                    Text="Copied configuration references TRADERELAY_MCP_TOKEN and never embeds the token value."
                    TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <Button Command="{Binding CopyCodexConfigCommand}" Content="Copy Codex config" />
                  <Button Command="{Binding CopyClaudeCodeCommand}" Content="Copy Claude Code command" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <TextBlock
              MinHeight="22"
              Foreground="#8BE0BD"
              Text="{Binding ActionMessage}"
              TextWrapping="Wrap" />
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <ScrollViewer Grid.Row="2" IsVisible="{Binding IsCredentialsSelected}">
      <Grid Margin="32" ColumnDefinitions="3*,2*" ColumnSpacing="24">
        <StackPanel Grid.Column="0" Spacing="18">
          <StackPanel Spacing="5">
            <TextBlock Classes="sectionTitle" Text="Bybit credentials" />
            <TextBlock Classes="muted" Text="Credentials are entered only here and are never exposed through MCP tools." TextWrapping="Wrap" />
          </StackPanel>
          <Border Padding="22" Background="#151E28" BorderBrush="#2A3644" BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="14">
              <TextBlock Classes="muted" Text="Environment" />
              <ComboBox ItemsSource="{Binding Environments}" SelectedItem="{Binding SelectedEnvironment, Mode=TwoWay}" />
              <TextBlock Classes="muted" Text="API key" />
              <TextBox Text="{Binding ApiKey, Mode=TwoWay}" PlaceholderText="Enter API key" />
              <TextBlock Classes="muted" Text="API secret" />
              <TextBox Text="{Binding ApiSecret, Mode=TwoWay}" PasswordChar="●" PlaceholderText="Enter API secret" />
              <CheckBox Content="Remember credentials on this device" IsChecked="{Binding RememberCredentials, Mode=TwoWay}" />
              <TextBlock Classes="muted" Text="Protected storage is used when available. Otherwise TradeRelay clearly falls back to this session only." TextWrapping="Wrap" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding TestConnectionCommand}" Content="Test connection" />
                <Button Classes="primary" Command="{Binding SaveCredentialsCommand}" Content="Save" />
                <Button Command="{Binding DeleteCredentialsCommand}" Content="Delete" />
              </StackPanel>
              <TextBlock Foreground="#8BE0BD" Text="{Binding CredentialActionStatus}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="18">
          <TextBlock Classes="sectionTitle" Text="Connection safety" />
          <Border Padding="20" Background="#151E28" BorderBrush="#2A3644" BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="12">
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Saved key" /><TextBlock Grid.Column="1" Classes="value" Text="{Binding SavedKeyPreview}" /></Grid>
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Storage" /><TextBlock Grid.Column="1" Classes="value" Text="{Binding CredentialStorageStatus}" /></Grid>
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="REST" /><TextBlock Grid.Column="1" Classes="value" Text="{Binding RestHealth}" /></Grid>
              <Grid ColumnDefinitions="*,Auto"><TextBlock Classes="muted" Text="Private stream" /><TextBlock Grid.Column="1" Classes="value" Text="{Binding StreamHealth}" /></Grid>
              <Separator Background="#2A3644" />
              <TextBlock FontWeight="SemiBold" Foreground="#E7EDF3" Text="Permission summary" />
              <TextBlock Classes="muted" Text="{Binding PermissionSummary}" TextWrapping="Wrap" />
              <TextBlock FontWeight="SemiBold" Foreground="#F1DA85" Text="Warnings" />
              <TextBlock Foreground="#D5CBA8" Text="{Binding CredentialWarnings}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Padding="18" Background="#351A1D" BorderBrush="#7A343B" BorderThickness="1" CornerRadius="10">
            <TextBlock Foreground="#F2A8AE" Text="TradeRelay rejects every API key with withdrawal permission. Read/write keys can enable only their matching environment after all session safety checks pass." TextWrapping="Wrap" />
          </Border>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <Grid Grid.Row="2" IsVisible="{Binding IsRiskSelected}">
      <localViews:RiskView DataContext="{Binding Risk}" />
    </Grid>
    <Grid Grid.Row="2" IsVisible="{Binding IsApprovalsSelected}">
      <localViews:ApprovalsView DataContext="{Binding Approvals}" />
    </Grid>
    <Grid Grid.Row="2" IsVisible="{Binding IsActivitySelected}">
      <localViews:ActivityView DataContext="{Binding Activity}" />
    </Grid>

    <Grid Grid.RowSpan="3" Background="#E60B1118" IsVisible="{Binding IsLiveEnableDialogOpen}">
      <Border
          Classes="panel"
          Width="620"
          MaxHeight="580"
          Padding="26"
          HorizontalAlignment="Center"
          VerticalAlignment="Center">
        <ScrollViewer>
          <StackPanel Spacing="16">
            <StackPanel Spacing="5">
              <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="Enable Live trading" />
              <TextBlock Classes="muted" Text="This enables real Bybit mainnet write operations for the current application session only." TextWrapping="Wrap" />
            </StackPanel>
            <Border Classes="liveBadge" Padding="16">
              <StackPanel Spacing="8">
                <TextBlock FontWeight="SemiBold" Foreground="{DynamicResource ErrorBrush}" Text="LIVE · REAL FUNDS AND POSITIONS" />
                <TextBlock Text="{Binding LiveRiskSummary}" TextWrapping="Wrap" />
              </StackPanel>
            </Border>
            <StackPanel Spacing="6">
              <TextBlock Classes="fieldLabel" Text="Credential warnings" />
              <TextBlock Classes="warningText" Text="{Binding LiveEnableWarnings}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Classes="fieldLabel" Text="Type ENABLE LIVE TRADING exactly" />
              <TextBox Text="{Binding LiveConfirmationText, Mode=TwoWay}" />
            </StackPanel>
            <TextBlock Classes="muted" Text="Enabling never cancels or changes existing exchange state. Disabling later blocks only new write actions." TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
              <Button Classes="quiet" Command="{Binding CancelLiveEnableCommand}" Content="Cancel" />
              <Button Classes="danger" Command="{Binding ConfirmLiveEnableCommand}" Content="Enable Live trading" />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</Window>
